---
// Quiz "Quel statut juridique ?" — Paul Entreprend
---

<div class="widget-section">
  <div id="quiz-container"></div>
</div>

<script>
const quizQs = [
  {
    label: "Question 1/5",
    text: "Tu lances ton activité seul ou avec des associés ?",
    options: [
      { text: "Seul", scores: { micro: 3, sasu: 3, eurl: 2, ei: 3 } },
      { text: "Avec des associés", scores: { sas: 3, sarl: 3 } },
      { text: "Pas encore sûr", scores: { micro: 1, sasu: 2 } }
    ]
  },
  {
    label: "Question 2/5",
    text: "Quel chiffre d'affaires vises-tu la première année ?",
    options: [
      { text: "Moins de 30 000 €", scores: { micro: 3, ei: 2 } },
      { text: "30K – 77K €", scores: { micro: 2, sasu: 2, eurl: 2 } },
      { text: "Plus de 77 700 €", scores: { sasu: 3, eurl: 3, sas: 2 } },
      { text: "Aucune idée", scores: { micro: 2 } }
    ]
  },
  {
    label: "Question 3/5",
    text: "Protéger ton patrimoine personnel, c'est important ?",
    options: [
      { text: "Oui, prioritaire", scores: { sasu: 3, eurl: 3, sas: 3 } },
      { text: "Non, activité peu risquée", scores: { micro: 3, ei: 2 } },
      { text: "Je ne sais pas", scores: { sasu: 2, micro: 1 } }
    ]
  },
  {
    label: "Question 4/5",
    text: "Comment veux-tu te rémunérer ?",
    options: [
      { text: "Simplement, sans fiche de paie", scores: { micro: 3, ei: 2, eurl: 2 } },
      { text: "En salaire avec fiche de paie", scores: { sasu: 3, sas: 3 } },
      { text: "Mix salaire + dividendes", scores: { sasu: 3, sas: 2 } },
      { text: "En dividendes principalement", scores: { sasu: 2, sas: 2 } }
    ]
  },
  {
    label: "Question 5/5",
    text: "Quelle est ta situation actuelle ?",
    options: [
      { text: "Salarié (je cumule)", scores: { micro: 3, sasu: 2 } },
      { text: "Demandeur d'emploi (ARE)", scores: { sasu: 3, micro: 2 } },
      { text: "Étudiant", scores: { micro: 3 } },
      { text: "Je me lance à 100%", scores: { sasu: 2, eurl: 2 } }
    ]
  }
];

const quizResults: Record<string, { title: string; desc: string; pros: string[]; cta: string; url: string }> = {
  micro: {
    title: "Micro-entreprise",
    desc: "Le statut le plus simple. Création gratuite, compta simplifiée, charges proportionnelles au CA.",
    pros: ["Création gratuite et rapide", "Zéro comptabilité complexe", "Charges sur le CA uniquement", "Idéal pour tester"],
    cta: "Créer ma micro-entreprise",
    url: "https://www.legalplace.fr/?ref=paulentreprend&statut=micro"
  },
  sasu: {
    title: "SASU",
    desc: "La société pour un entrepreneur solo. Salaire + dividendes optimisables, patrimoine protégé.",
    pros: ["Patrimoine protégé", "Salaire + dividendes", "Crédibilité clients", "Compatible ARE/ARCE"],
    cta: "Créer ma SASU",
    url: "https://www.legalplace.fr/?ref=paulentreprend&statut=sasu"
  },
  eurl: {
    title: "EURL",
    desc: "Société unipersonnelle au régime TNS. Charges sociales réduites vs SASU.",
    pros: ["Charges sociales réduites", "Option IR ou IS", "Patrimoine protégé", "Passage SARL facile"],
    cta: "Créer mon EURL",
    url: "https://www.legalplace.fr/?ref=paulentreprend&statut=eurl"
  },
  sas: {
    title: "SAS",
    desc: "Pour s'associer avec flexibilité. Idéale pour lever des fonds.",
    pros: ["Souplesse statutaire", "Plusieurs associés", "Levée de fonds facile", "Président assimilé-salarié"],
    cta: "Créer ma SAS",
    url: "https://www.legalplace.fr/?ref=paulentreprend&statut=sas"
  },
  sarl: {
    title: "SARL",
    desc: "La classique pour s'associer. Cadre juridique bien défini.",
    pros: ["Cadre sécurisant", "Charges gérant réduites", "Idéale en famille", "Connue des banques"],
    cta: "Créer ma SARL",
    url: "https://www.legalplace.fr/?ref=paulentreprend&statut=sarl"
  },
  ei: {
    title: "Entreprise individuelle",
    desc: "Comme la micro mais sans plafond de CA. Option IS possible.",
    pros: ["Pas de plafond CA", "Création simple", "Option IS", "Compta simplifiée"],
    cta: "Créer mon EI",
    url: "https://www.legalplace.fr/?ref=paulentreprend&statut=ei"
  }
};

let qCur = 0;
let qScores: Record<string, number> = {};
let qAnswers: number[] = [];

function qBack() {
  if (qCur <= 0) return;
  qCur--;
  const prevAnswer = qAnswers[qCur];
  if (prevAnswer !== undefined) {
    const s = quizQs[qCur].options[prevAnswer].scores;
    for (const [k, v] of Object.entries(s)) qScores[k] = (qScores[k] || 0) - v;
    delete qAnswers[qCur];
  }
  qRender();
}

function qRender() {
  const el = document.getElementById('quiz-container');
  if (!el) return;

  const dots = quizQs.map((_, i) => {
    const cls = i < qCur ? 'done' : i === qCur ? 'active' : '';
    return `<div class="quiz-dot ${cls}"></div>`;
  }).join('');

  if (qCur < quizQs.length) {
    const q = quizQs[qCur];
    const backBtn = qCur > 0 ? `<span class="quiz-back">← Question précédente</span>` : '';
    el.innerHTML = `
      <div class="quiz-progress">${dots}</div>
      ${backBtn}
      <div class="quiz-label">${q.label}</div>
      <div class="quiz-q">${q.text}</div>
      ${q.options.map((o, i) => `<div class="quiz-opt" data-i="${i}">${o.text}</div>`).join('')}
    `;
    el.querySelectorAll('.quiz-opt').forEach(opt => {
      opt.addEventListener('click', () => qAnswer(Number((opt as HTMLElement).dataset.i)));
    });
    el.querySelector('.quiz-back')?.addEventListener('click', qBack);
  } else {
    const sorted = Object.entries(qScores).sort((a, b) => b[1] - a[1]);
    let best = sorted[0]?.[0] ?? 'micro';
    if (!quizResults[best]) best = 'micro';
    const r = quizResults[best];
    el.innerHTML = `
      <div class="quiz-progress">${quizQs.map(() => '<div class="quiz-dot done"></div>').join('')}</div>
      <div class="quiz-result">
        <div class="quiz-badge">Recommandé pour toi</div>
        <h3>${r.title}</h3>
        <p>${r.desc}</p>
        <div class="quiz-pros">${r.pros.map(p => `<div class="quiz-pro">✓ ${p}</div>`).join('')}</div>
        <a href="${r.url}" class="cta-btn primary" target="_blank" rel="noopener sponsored">${r.cta} →</a>
      </div>
      <span class="quiz-restart">Refaire le quiz</span>
    `;
    el.querySelector('.quiz-restart')?.addEventListener('click', () => {
      qCur = 0; qScores = {}; qAnswers = []; qRender();
    });
  }
}

function qAnswer(i: number) {
  const opts = document.querySelectorAll('.quiz-opt');
  opts[i]?.classList.add('sel');
  const s = quizQs[qCur].options[i].scores;
  for (const [k, v] of Object.entries(s)) qScores[k] = (qScores[k] ?? 0) + v;
  qAnswers[qCur] = i;
  setTimeout(() => { qCur++; qRender(); }, 250);
}

qRender();
</script>

<!-- styles dans article.css (global) -->

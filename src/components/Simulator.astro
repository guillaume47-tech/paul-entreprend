---
// Simulateur Micro-entreprise vs SASU — Paul Entreprend
---

<div class="widget-section">
  <div class="sim-wrap">
    <div class="sim-title">Simulateur : combien il te reste en poche ?</div>
    <div class="sim-sub">Compare micro-entreprise vs SASU selon ton CA, ton imposition et tes charges réelles</div>

    <div class="sim-input">
      <div class="sim-input-header">
        <span>Chiffre d'affaires annuel</span>
        <span class="sim-input-val" id="sim-ca-val">50 000 €</span>
      </div>
      <input type="range" min="10000" max="200000" step="5000" value="50000" id="sim-ca" />
    </div>

    <div class="sim-input">
      <div class="sim-input-header">
        <span>Taux marginal d'imposition</span>
        <span class="sim-input-val" id="sim-tmi-val">30%</span>
      </div>
      <input type="range" min="0" max="45" step="1" value="30" id="sim-tmi" />
    </div>

    <div class="sim-input">
      <div class="sim-input-header">
        <span>Charges professionnelles (% du CA)</span>
        <span class="sim-input-val" id="sim-charges-val">10%</span>
      </div>
      <input type="range" min="0" max="50" step="5" value="10" id="sim-charges" />
      <div class="sim-charges-hint">Outils, abonnements, déplacements, sous-traitance… En micro, ces charges ne sont pas déductibles.</div>
    </div>

    <div class="sim-toggle-label">Type d'activité</div>
    <div class="sim-toggle">
      <div class="sim-toggle-btn active" data-type="service" id="btn-service">Prestation de service</div>
      <div class="sim-toggle-btn" data-type="commerce" id="btn-commerce">Vente de marchandises</div>
    </div>

    <div id="sim-result"></div>
    <div class="sim-note" id="sim-note"></div>
  </div>
</div>

<script>
let simType = 'service';

function simFmt(n: number) {
  return Math.round(n).toLocaleString('fr-FR') + ' €';
}

function simSetType(t: string) {
  simType = t;
  document.querySelectorAll('.sim-toggle-btn').forEach(b => {
    b.classList.toggle('active', (b as HTMLElement).dataset.type === t);
  });
  simCalc();
}

function simCalc() {
  const ca = Number((document.getElementById('sim-ca') as HTMLInputElement).value);
  const tmi = Number((document.getElementById('sim-tmi') as HTMLInputElement).value) / 100;
  const chargesPct = Number((document.getElementById('sim-charges') as HTMLInputElement).value) / 100;

  const caValEl = document.getElementById('sim-ca-val');
  const tmiValEl = document.getElementById('sim-tmi-val');
  const chargesValEl = document.getElementById('sim-charges-val');
  if (caValEl) caValEl.textContent = simFmt(ca);
  if (tmiValEl) tmiValEl.textContent = Math.round(tmi * 100) + '%';
  if (chargesValEl) chargesValEl.textContent = Math.round(chargesPct * 100) + '% (' + simFmt(ca * chargesPct) + ')';

  // MICRO
  const cotM = simType === 'service' ? 0.231 : 0.124;
  const abat = simType === 'service' ? 0.50 : 0.71;
  const mCotis = ca * cotM;
  const mIR = ca * (1 - abat) * tmi;
  const mChargesReelles = ca * chargesPct;
  const mNet = ca - mCotis - mIR - mChargesReelles;

  // SASU
  const chargesReelles = ca * chargesPct;
  const comptaCost = 1500;
  const caNet = ca - chargesReelles - comptaCost;
  const sBr = Math.max(0, caNet * 0.5);
  const sPatron = sBr * 0.45;
  const sSal = sBr * 0.22;
  const sNetSalaire = sBr - sSal;
  const sResultat = Math.max(0, caNet - sBr - sPatron);
  const sIS = sResultat <= 42500 ? sResultat * 0.15 : 42500 * 0.15 + (sResultat - 42500) * 0.25;
  const sDivBrut = Math.max(0, sResultat - sIS);
  const sDivNet = sDivBrut * 0.70;
  const sIRsalaire = sNetSalaire * tmi;
  const sTotal = sNetSalaire - sIRsalaire + sDivNet;

  const mPct = ca > 0 ? Math.round(mNet / ca * 100) : 0;
  const sPct = ca > 0 ? Math.round(sTotal / ca * 100) : 0;
  const w = mNet >= sTotal ? 'micro' : 'sasu';
  const diff = Math.abs(mNet - sTotal);

  const detailMicro = `Cotisations ${simFmt(mCotis)} · IR ${simFmt(mIR)} · Charges réelles ${simFmt(mChargesReelles)} (non déduites)`;
  const detailSasu = `Salaire net ${simFmt(sNetSalaire)} · IR ${simFmt(sIRsalaire)} · Dividendes nets ${simFmt(sDivNet)} · Compta ${simFmt(comptaCost)}`;

  const resultEl = document.getElementById('sim-result');
  if (resultEl) {
    resultEl.innerHTML = `
      <div class="sim-cards">
        <div class="sim-card">
          <div class="sim-card-label">Micro-entreprise${w === 'micro' ? '<span class="sim-winner sim-winner-purple">+ rentable</span>' : ''}</div>
          <div class="sim-card-val sim-purple">${simFmt(mNet)}</div>
          <div class="sim-card-sub">${mPct}% du CA en poche</div>
          <div class="sim-card-detail">${detailMicro}</div>
        </div>
        <div class="sim-card">
          <div class="sim-card-label">SASU${w === 'sasu' ? '<span class="sim-winner sim-winner-green">+ rentable</span>' : ''}</div>
          <div class="sim-card-val sim-green">${simFmt(sTotal)}</div>
          <div class="sim-card-sub">${sPct}% du CA en poche</div>
          <div class="sim-card-detail">${detailSasu}</div>
        </div>
      </div>
    `;
  }

  let noteExtra = '';
  if (chargesPct >= 0.15) {
    noteExtra = ` En micro, tes charges réelles ne sont pas déductibles — l'abattement forfaitaire de ${simType === 'service' ? '50' : '71'}% est censé les couvrir.`;
  }

  const noteEl = document.getElementById('sim-note');
  if (noteEl) {
    noteEl.innerHTML = `Différence : <strong>${simFmt(diff)}/an</strong> en faveur de la <strong>${w === 'micro' ? 'micro-entreprise' : 'SASU'}</strong>. Taux URSSAF 2026, IS 15% puis 25%, flat tax 30%.${noteExtra}`;
  }
}

document.getElementById('sim-ca')?.addEventListener('input', simCalc);
document.getElementById('sim-tmi')?.addEventListener('input', simCalc);
document.getElementById('sim-charges')?.addEventListener('input', simCalc);
document.getElementById('btn-service')?.addEventListener('click', () => simSetType('service'));
document.getElementById('btn-commerce')?.addEventListener('click', () => simSetType('commerce'));

simCalc();
</script>

<!-- styles dans article.css (global) -->

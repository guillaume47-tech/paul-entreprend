---
// Simulateur Micro-entreprise vs SASU — Paul Entreprend v2
---

<div class="widget-section">
  <div class="sim-wrap">
    <div class="sim-title">Simulateur : combien il te reste en poche ?</div>
    <div class="sim-sub">Compare micro-entreprise vs SASU selon ton CA, ton imposition et tes charges réelles</div>

    <div class="sim-input">
      <div class="sim-input-header">
        <span>Chiffre d'affaires annuel</span>
        <span class="sim-input-val" id="sim-ca-val">50 000 €</span>
      </div>
      <input type="range" min="10000" max="200000" step="5000" value="50000" id="sim-ca" />
    </div>

    <div class="sim-input">
      <div class="sim-input-header">
        <span>Taux marginal d'imposition (TMI)</span>
        <span class="sim-input-val" id="sim-tmi-val">30%</span>
      </div>
      <input type="range" min="0" max="45" step="1" value="30" id="sim-tmi" />
    </div>

    <div class="sim-input">
      <div class="sim-input-header">
        <span>Charges professionnelles</span>
        <span class="sim-input-val" id="sim-charges-val">10%</span>
      </div>
      <input type="range" min="0" max="50" step="5" value="10" id="sim-charges" />
      <div class="sim-charges-hint">Outils, abonnements, déplacements, sous-traitance… En micro, ces charges ne sont pas déductibles.</div>
      <div class="sim-trap-note" id="sim-trap-note"></div>
    </div>

    <div class="sim-toggle-label">Type d'activité</div>
    <div class="sim-toggle">
      <div class="sim-toggle-btn active" data-type="bnc" id="btn-bnc">BNC / Libérale</div>
      <div class="sim-toggle-btn" data-type="service" id="btn-service">BIC Services</div>
      <div class="sim-toggle-btn" data-type="vente" id="btn-vente">Vente</div>
    </div>
    <div class="sim-type-hint" id="sim-type-hint">Consultant, dev, graphiste, formateur, coach…</div>

    <div id="sim-result"></div>
    <div class="sim-note" id="sim-note"></div>
  </div>
</div>

<script>
const MICRO_PARAMS: Record<string, { cotisation: number; abattement: number }> = {
  bnc:     { cotisation: 0.234, abattement: 0.34 },
  service: { cotisation: 0.215, abattement: 0.50 },
  vente:   { cotisation: 0.124, abattement: 0.71  },
};

const TYPE_HINTS: Record<string, string> = {
  bnc:     'Consultant, dev, graphiste, formateur, coach…',
  service: 'Artisan, transport, réparation, restauration…',
  vente:   'E-commerce, achat-revente, commerce de détail…',
};

let simType = 'bnc';

function fmt(n: number, sign = false): string {
  const abs = Math.round(Math.abs(n)).toLocaleString('fr-FR');
  if (sign && n < 0) return `<span class="sim-neg">−${abs} €</span>`;
  if (sign && n > 0) return `+${abs} €`;
  return `${Math.round(n).toLocaleString('fr-FR')} €`;
}

function pct(n: number, total: number): string {
  return total > 0 ? Math.round(n / total * 100) + '%' : '0%';
}

function simSetType(t: string) {
  simType = t;
  document.querySelectorAll('.sim-toggle-btn').forEach(b => {
    b.classList.toggle('active', (b as HTMLElement).dataset.type === t);
  });
  const hint = document.getElementById('sim-type-hint');
  if (hint) hint.textContent = TYPE_HINTS[t];
  simCalc();
}

function simCalc() {
  const ca = Number((document.getElementById('sim-ca') as HTMLInputElement).value);
  const tmi = Number((document.getElementById('sim-tmi') as HTMLInputElement).value) / 100;
  const chargesPct = Number((document.getElementById('sim-charges') as HTMLInputElement).value) / 100;

  // Mise à jour labels
  const caValEl = document.getElementById('sim-ca-val');
  const tmiValEl = document.getElementById('sim-tmi-val');
  const chargesValEl = document.getElementById('sim-charges-val');
  if (caValEl) caValEl.textContent = fmt(ca);
  if (tmiValEl) tmiValEl.textContent = Math.round(tmi * 100) + '%';
  if (chargesValEl) chargesValEl.textContent = Math.round(chargesPct * 100) + '% (' + fmt(ca * chargesPct) + ')';

  const { cotisation, abattement } = MICRO_PARAMS[simType];

  // Note piège micro (toujours visible)
  const trapEl = document.getElementById('sim-trap-note');
  if (trapEl) {
    trapEl.innerHTML = `En micro-entreprise, tes charges réelles ne réduisent PAS ton impôt. L'abattement forfaitaire de <strong>${Math.round(abattement * 100)}%</strong> est un forfait fixe, même si tes charges réelles dépassent ce montant.`;
  }

  // ===== MICRO =====
  const mCotis = ca * cotisation;
  const mRevenuImposable = ca * (1 - abattement);
  const mIR = mRevenuImposable * tmi;
  const mCharges = ca * chargesPct;
  const mNet = ca - mCotis - mIR - mCharges;

  // ===== SASU =====
  const sCharges = ca * chargesPct;
  const sCompta = 1500;
  const sCaNet = ca - sCharges - sCompta;
  const sSalBrut = Math.max(0, sCaNet * 0.5);
  const sPatron = sSalBrut * 0.45;
  const sSalCh = sSalBrut * 0.22;
  const sSalNet = sSalBrut - sSalCh;
  const sIRSal = sSalNet * tmi;
  const sSalNetIR = sSalNet - sIRSal;
  const sResultat = Math.max(0, sCaNet - sSalBrut - sPatron);
  const sIS = sResultat <= 42500 ? sResultat * 0.15 : 42500 * 0.15 + (sResultat - 42500) * 0.25;
  const sDivBrut = Math.max(0, sResultat - sIS);
  const sFlatTax = sDivBrut * 0.30;
  const sDivNet = sDivBrut - sFlatTax;
  const sNet = sSalNetIR + sDivNet;

  const mPct = pct(mNet, ca);
  const sPct = pct(sNet, ca);
  const winner = mNet >= sNet ? 'micro' : 'sasu';
  const diff = Math.abs(mNet - sNet);

  const typeLabel: Record<string, string> = { bnc: 'BNC/Libérale', service: 'BIC Services', vente: 'Vente' };

  // ===== RENDU CARDS =====
  const resultEl = document.getElementById('sim-result');
  if (resultEl) {
    resultEl.innerHTML = `
      <div class="sim-cards-v2">

        <div class="sim-card-v2${winner === 'micro' ? ' sim-card-winner' : ''}">
          <div class="sim-card-header">
            <span class="sim-card-name">Micro-entreprise</span>
            ${winner === 'micro' ? '<span class="sim-badge sim-badge-winner">+ rentable</span>' : ''}
          </div>
          <div class="sim-card-net">${fmt(mNet)}</div>
          <div class="sim-pct">${mPct} du CA</div>
          <div class="sim-breakdown">
            <div class="sim-line"><span>CA brut</span><span>${fmt(ca)}</span></div>
            <div class="sim-line sim-line-neg"><span>Cotisations (${Math.round(cotisation * 100)}%)</span><span>${fmt(-mCotis, true)}</span></div>
            <div class="sim-line sim-line-neg"><span>IR (abat. ${Math.round(abattement * 100)}%, TMI ${Math.round(tmi * 100)}%)</span><span>${fmt(-mIR, true)}</span></div>
            <div class="sim-line sim-line-neg"><span>Charges réelles <em>non déductibles</em></span><span>${fmt(-mCharges, true)}</span></div>
          </div>
        </div>

        <div class="sim-card-v2${winner === 'sasu' ? ' sim-card-winner' : ''}">
          <div class="sim-card-header">
            <span class="sim-card-name">SASU</span>
            ${winner === 'sasu' ? '<span class="sim-badge sim-badge-winner">+ rentable</span>' : ''}
          </div>
          <div class="sim-card-net">${fmt(sNet)}</div>
          <div class="sim-pct">${sPct} du CA</div>
          <div class="sim-breakdown">
            <div class="sim-line"><span>CA brut</span><span>${fmt(ca)}</span></div>
            <div class="sim-line sim-line-neg"><span>Charges + compta</span><span>${fmt(-(sCharges + sCompta), true)}</span></div>
            <div class="sim-line sim-line-neg"><span>Cotis. patronales + IS + flat tax</span><span>${fmt(-(sPatron + sIS + sFlatTax), true)}</span></div>
            <div class="sim-line sim-line-neg"><span>IR sur salaire</span><span>${fmt(-sIRSal, true)}</span></div>
          </div>
        </div>

      </div>
    `;
  }

  // ===== NOTE DYNAMIQUE =====
  const noteEl = document.getElementById('sim-note');
  if (noteEl) {
    const caStr = fmt(ca);
    const diffStr = fmt(diff);
    const tLabel = typeLabel[simType];
    let note = '';
    if (diff < 2000) {
      note = `Les deux statuts se valent à ce niveau de CA. La SASU offre une meilleure protection sociale et plus de flexibilité d'évolution — c'est souvent ce qui fait la différence.`;
    } else if (winner === 'micro') {
      note = `À ${caStr} de CA en ${tLabel}, la micro-entreprise te laisse <strong>${diffStr} de plus par an</strong>. Mais si ton CA augmente ou tes charges montent, refais la simulation — le point de bascule est souvent plus bas qu'on ne croit.`;
    } else {
      note = `À ${caStr} de CA en ${tLabel}, la SASU te laisse <strong>${diffStr} de plus par an</strong> grâce à la déduction des charges réelles et l'optimisation salaire + dividendes. <a href="https://www.legalplace.fr/?ref=paulentreprend" target="_blank" rel="noopener sponsored">Créer ma SASU avec LegalPlace →</a>`;
    }
    noteEl.innerHTML = `
      <div class="sim-note-main">${note}</div>
      <div class="sim-note-legal">Simulation indicative — taux URSSAF 2026, IS 15%/25%, flat tax 30%. Consultez un expert-comptable pour votre situation.</div>
    `;
  }
}

document.getElementById('sim-ca')?.addEventListener('input', simCalc);
document.getElementById('sim-tmi')?.addEventListener('input', simCalc);
document.getElementById('sim-charges')?.addEventListener('input', simCalc);
document.getElementById('btn-bnc')?.addEventListener('click', () => simSetType('bnc'));
document.getElementById('btn-service')?.addEventListener('click', () => simSetType('service'));
document.getElementById('btn-vente')?.addEventListener('click', () => simSetType('vente'));

simCalc();
</script>

<!-- styles dans article.css (global) -->

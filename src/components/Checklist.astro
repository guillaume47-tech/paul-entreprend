---
interface Props {
  title?: string;
  items: string[];
}
const { title = 'Checklist', items } = Astro.props;
---

<div class="widget-section">
  <div class="check-wrap">
    <div class="check-header">
      <span class="check-title">{title}</span>
      <span class="check-progress" id="check-count">0/{items.length}</span>
    </div>
    <div class="check-bar"><div class="check-fill" id="check-bar"></div></div>
    <div id="check-items">
      {items.map((item, i) => (
        <label class="check-item" id={`ci-${i}`}>
          <input type="checkbox" data-i={i} />
          <span>{item}</span>
        </label>
      ))}
    </div>
  </div>
</div>

<script>
function checkUpdate() {
  const boxes = document.querySelectorAll('#check-items input[type=checkbox]');
  const total = boxes.length;
  const done = [...boxes].filter(b => (b as HTMLInputElement).checked).length;
  const countEl = document.getElementById('check-count');
  const barEl = document.getElementById('check-bar');
  if (countEl) countEl.textContent = `${done}/${total}`;
  if (barEl) barEl.style.width = Math.round(done / total * 100) + '%';
  boxes.forEach((b, i) => {
    const label = document.getElementById(`ci-${i}`);
    if (label) label.classList.toggle('done', (b as HTMLInputElement).checked);
  });
}
document.querySelectorAll('#check-items input[type=checkbox]').forEach(b => {
  b.addEventListener('change', checkUpdate);
});
</script>


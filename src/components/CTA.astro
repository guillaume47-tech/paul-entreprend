---
interface Props {
  type: 'legalplace' | 'qonto';
  variant?: 'blue' | 'green';
  title?: string;
  sub?: string;
  label?: string;
}

const { type, variant, title, sub, label } = Astro.props;

const defaults = {
  legalplace: {
    title: 'Créer ta SASU gratuitement',
    sub: 'Statuts, annonce légale et dépôt gérés pour toi — tu ne paies que les ~200€ de frais administratifs',
    label: 'Créer ma SASU avec LegalPlace →',
    url: 'https://www.legalplace.fr/?ref=paulentreprend',
    variant: 'blue',
  },
  qonto: {
    title: 'Ouvrir un compte pro + déposer ton capital',
    sub: 'Dépôt de capital en ligne, attestation rapide, compte pro inclus',
    label: 'Ouvrir un compte Qonto →',
    url: 'https://qonto.com/fr/?ref=paulentreprend',
    variant: 'green',
  },
};

const d = defaults[type];
const color = (variant ?? d.variant) === 'green' ? 'green' : 'primary';
---

<div class={`cta-box${color === 'green' ? ' green' : ''}`}>
  <div class="cta-text">
    <div class="cta-title">{title ?? d.title}</div>
    <div class="cta-sub">{sub ?? d.sub}</div>
  </div>
  <a href={d.url} class={`cta-btn ${color}`} target="_blank" rel="noopener sponsored">
    {label ?? d.label}
  </a>
</div>

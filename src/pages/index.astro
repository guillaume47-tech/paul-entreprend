---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const recent = allArticles
  .sort((a, b) => (b.data.updatedDate ?? b.data.pubDate).getTime() - (a.data.updatedDate ?? a.data.pubDate).getTime())
  .slice(0, 6);

const clusters = [
  { name: 'Micro-entreprise', slug: 'micro-entreprise', desc: 'Le statut le plus simple pour démarrer' },
  { name: 'SASU', slug: 'creer-une-sasu', desc: 'La société préférée des entrepreneurs solo' },
  { name: 'EURL', slug: 'creer-une-eurl', desc: 'La SARL à un seul associé, régime TNS' },
  { name: 'SARL / SAS', slug: 'creer-une-sarl', desc: 'Pour s\'associer avec un cadre clair' },
  { name: 'Compte bancaire pro', slug: 'compte-bancaire-professionnel', desc: 'Qonto, Shine, Revolut… lequel choisir' },
  { name: 'Comparatifs statuts', slug: 'comparatifs', desc: 'Quel statut est fait pour toi ?' },
];
---

<BaseLayout
  title="Paul Entreprend — Créer son entreprise en France"
  description="Guides concrets pour créer ta micro-entreprise, SASU, EURL ou SARL en France. Coûts réels, démarches étape par étape. Par un entrepreneur, pas un juriste."
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow">Par un entrepreneur, pas un juriste</div>
        <h1>Créer son entreprise en France sans se noyer dans le jargon</h1>
        <p>J'ai créé ma SASU en 2023. Des heures perdues sur des articles vagues, des coûts cachés, des erreurs que j'aurais pu éviter. Ces guides, c'est ce que j'aurais voulu lire avant.</p>
        <div class="hero-ctas">
          <a href="/creer-une-sasu" class="btn-primary">Créer une SASU →</a>
          <a href="/micro-entreprise" class="btn-secondary">Micro-entreprise →</a>
          <a href="/comparatifs" class="btn-ghost">Quel statut choisir ?</a>
        </div>
      </div>
      <div class="hero-stats">
        <div class="stat-card">
          <div class="stat-num">238€</div>
          <div class="stat-label">Coût réel de création d'une SASU</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">7 jours</div>
          <div class="stat-label">Délai moyen pour recevoir le Kbis</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">13 clusters</div>
          <div class="stat-label">Thèmes couverts sur ce site</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CLUSTERS -->
  <section class="clusters-section">
    <div class="section-inner">
      <div class="section-header">
        <h2>Tous les guides par statut</h2>
        <p>De la micro-entreprise à la holding, chaque statut a son guide complet avec coûts réels et démarches pas à pas.</p>
      </div>
      <div class="clusters-grid">
        {clusters.map((cluster) => (
          <a href={`/${cluster.slug}`} class="cluster-card">
            <div class="cluster-name">{cluster.name}</div>
            <div class="cluster-desc">{cluster.desc}</div>
            <div class="cluster-arrow">→</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- POURQUOI PAUL -->
  <section class="why-section">
    <div class="section-inner">
      <div class="why-grid">
        <div class="why-content">
          <h2>Pourquoi faire confiance à Paul ?</h2>
          <p>Je suis entrepreneur, pas juriste. J'ai créé ma première structure en 2023 et j'ai documenté chaque étape, chaque coût, chaque galère. Ce que tu lis ici, c'est de l'expérience vécue — pas de la théorie.</p>
          <ul class="why-list">
            <li>Coûts exacts au centime près (238,45€ pour ma SASU, pas "entre 200€ et 500€")</li>
            <li>Aucun affichage publicitaire — uniquement des recommandations d'outils que j'utilise vraiment</li>
            <li>Mis à jour régulièrement avec les dernières évolutions légales et fiscales</li>
          </ul>
        </div>
        <div class="why-card">
          <div class="paul-badge">Ce que Paul en pense</div>
          <p>"La plupart des articles sur la création d'entreprise sont écrits par des juristes ou des agences de contenu. Ils sont corrects mais inutilement vagues. Moi j'écris en tant qu'entrepreneur qui a fait les démarches lui-même, payé les factures, et compris ce qui compte vraiment."</p>
          <div class="paul-sig">— Paul, entrepreneur depuis 2023</div>
        </div>
      </div>
    </div>
  </section>

  <!-- DERNIERS ARTICLES -->
  {recent.length > 0 && (
    <section class="articles-section">
      <div class="section-inner">
        <div class="section-header">
          <h2>Derniers guides publiés</h2>
        </div>
        <div class="articles-grid">
          {recent.map((article) => (
            <a href={`/${article.id}`} class="article-card">
              <div class="article-cluster">{article.data.cluster}</div>
              <div class="article-title">{article.data.title}</div>
              <div class="article-desc">{article.data.description}</div>
              <div class="article-link">Lire le guide →</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
/* ===== HERO ===== */
.hero {
  background: linear-gradient(135deg, #3058e5 0%, #192152 100%);
  color: #fff;
  padding: 80px 24px;
}
.hero-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 60px;
  align-items: center;
}
.hero-eyebrow {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #fefbc5;
  margin-bottom: 16px;
}
.hero h1 {
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -0.5px;
  margin: 0 0 20px;
}
.hero p {
  font-size: 17px;
  line-height: 1.7;
  color: rgba(255,255,255,.8);
  margin-bottom: 32px;
}
.hero-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
.btn-primary {
  background: #fefbc5;
  color: #192152;
  font-weight: 700;
  font-size: 15px;
  padding: 13px 24px;
  border-radius: 8px;
  text-decoration: none;
  transition: background .15s;
}
.btn-primary:hover { background: #fdf5a0; }
.btn-secondary {
  background: rgba(255,255,255,.15);
  color: #fff;
  font-weight: 600;
  font-size: 15px;
  padding: 13px 24px;
  border-radius: 8px;
  text-decoration: none;
  border: 1.5px solid rgba(255,255,255,.3);
  transition: background .15s;
}
.btn-secondary:hover { background: rgba(255,255,255,.25); }
.btn-ghost {
  color: rgba(255,255,255,.7);
  font-size: 14px;
  font-weight: 500;
  padding: 13px 8px;
  text-decoration: none;
  transition: color .15s;
}
.btn-ghost:hover { color: #fff; }

.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.stat-card {
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 12px;
  padding: 20px 24px;
  backdrop-filter: blur(4px);
}
.stat-num {
  font-size: 28px;
  font-weight: 800;
  color: #fefbc5;
  line-height: 1;
  margin-bottom: 4px;
}
.stat-label {
  font-size: 13px;
  color: rgba(255,255,255,.7);
}

/* ===== SECTIONS ===== */
.section-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}
.section-header {
  margin-bottom: 40px;
}
.section-header h2 {
  font-size: 28px;
  font-weight: 800;
  color: #192152;
  margin: 0 0 10px;
  letter-spacing: -0.3px;
}
.section-header p {
  font-size: 16px;
  color: #64748b;
}

/* ===== CLUSTERS ===== */
.clusters-section {
  padding: 80px 0;
  background: #f8faff;
}
.clusters-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.cluster-card {
  background: #fff;
  border: 1.5px solid #e2e8f0;
  border-radius: 12px;
  padding: 24px;
  text-decoration: none;
  transition: all .2s;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.cluster-card:hover {
  border-color: #3058e5;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(48,88,229,.1);
}
.cluster-name {
  font-size: 17px;
  font-weight: 700;
  color: #192152;
}
.cluster-card:hover .cluster-name { color: #3058e5; }
.cluster-desc {
  font-size: 13px;
  color: #64748b;
  line-height: 1.5;
  flex: 1;
}
.cluster-arrow {
  font-size: 16px;
  color: #3058e5;
  margin-top: 8px;
  font-weight: 600;
}

/* ===== WHY ===== */
.why-section {
  padding: 80px 0;
}
.why-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}
.why-content h2 {
  font-size: 28px;
  font-weight: 800;
  color: #192152;
  margin: 0 0 16px;
}
.why-content p {
  font-size: 16px;
  color: #475569;
  line-height: 1.7;
  margin-bottom: 24px;
}
.why-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.why-list li {
  font-size: 15px;
  color: #334155;
  padding-left: 24px;
  position: relative;
  line-height: 1.5;
}
.why-list li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: #3058e5;
  font-weight: 700;
}
.why-card {
  background: #f8faff;
  border: 1.5px solid #dbeafe;
  border-radius: 16px;
  padding: 32px;
}
.paul-badge {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: #3058e5;
  margin-bottom: 16px;
}
.why-card p {
  font-size: 15px;
  line-height: 1.7;
  color: #334155;
  font-style: italic;
  margin: 0 0 16px;
}
.paul-sig {
  font-size: 13px;
  font-weight: 600;
  color: #64748b;
}

/* ===== ARTICLES ===== */
.articles-section {
  padding: 80px 0;
  background: #f8faff;
}
.articles-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.article-card {
  background: #fff;
  border: 1.5px solid #e2e8f0;
  border-radius: 12px;
  padding: 24px;
  text-decoration: none;
  transition: all .2s;
  display: flex;
  flex-direction: column;
}
.article-card:hover {
  border-color: #3058e5;
  box-shadow: 0 8px 24px rgba(48,88,229,.08);
}
.article-cluster {
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: #3058e5;
  margin-bottom: 8px;
}
.article-title {
  font-size: 16px;
  font-weight: 700;
  color: #192152;
  line-height: 1.35;
  margin-bottom: 8px;
}
.article-card:hover .article-title { color: #3058e5; }
.article-desc {
  font-size: 13px;
  color: #64748b;
  line-height: 1.5;
  flex: 1;
  margin-bottom: 16px;
}
.article-link {
  font-size: 13px;
  font-weight: 600;
  color: #3058e5;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .hero-inner { grid-template-columns: 1fr; }
  .hero-stats { flex-direction: row; }
  .clusters-grid { grid-template-columns: repeat(2, 1fr); }
  .why-grid { grid-template-columns: 1fr; }
  .articles-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .hero { padding: 48px 24px; }
  .hero-stats { flex-direction: column; }
  .clusters-grid { grid-template-columns: 1fr; }
  .articles-grid { grid-template-columns: 1fr; }
}
</style>

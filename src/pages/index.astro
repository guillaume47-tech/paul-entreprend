---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const recent = allArticles
  .sort((a, b) => (b.data.updatedDate ?? b.data.pubDate).getTime() - (a.data.updatedDate ?? a.data.pubDate).getTime())
  .slice(0, 6);

const clusters = [
  { name: 'Micro-entreprise', slug: 'micro-entreprise' },
  { name: 'SASU', slug: 'sasu' },
  { name: 'Statuts : lequel choisir ?', slug: 'comparatifs' },
  { name: 'Fiscalité & aides', slug: 'fiscalite' },
  { name: 'Compte bancaire pro', slug: 'banques-pro' },
  { name: 'Comptabilité & outils', slug: 'comptabilite' },
];
---

<BaseLayout
  title="Paul Entreprend — Créer son entreprise en France"
  description="Guides concrets pour créer ta micro-entreprise, SASU, EURL ou SARL. Par un entrepreneur, pas un juriste."
>

  <!-- Hero -->
  <section class="max-w-2xl mx-auto px-4 pt-14 pb-10">
    <p class="text-sm text-gray-400 uppercase tracking-widest mb-4">paul-entreprend.fr</p>
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-snug mb-5">
      J'ai créé ma SASU en 2023.<br />
      Voilà tout ce que j'aurais voulu savoir avant.
    </h1>
    <p class="text-gray-600 text-lg leading-relaxed mb-6">
      Je suis Paul, pas juriste. J'ai passé des heures à chercher des infos claires sur la création d'entreprise en France — et à tomber sur des articles vagues écrits par des gens qui n'ont jamais créé de boîte. Alors je les écris moi-même.
    </p>
    <p class="text-gray-500 text-base mb-8">
      Coûts réels, démarches étape par étape, erreurs à éviter. Rien de plus.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/creer-micro-entreprise" class="bg-gray-900 text-white font-medium px-5 py-2.5 rounded-lg hover:bg-gray-700 transition-colors text-sm">
        Micro-entreprise →
      </a>
      <a href="/creer-sasu" class="bg-gray-900 text-white font-medium px-5 py-2.5 rounded-lg hover:bg-gray-700 transition-colors text-sm">
        SASU →
      </a>
      <a href="/comparatifs" class="border border-gray-300 text-gray-700 font-medium px-5 py-2.5 rounded-lg hover:bg-gray-50 transition-colors text-sm">
        Quel statut choisir ?
      </a>
    </div>
  </section>

  <div class="max-w-2xl mx-auto px-4">
    <hr class="border-gray-100" />
  </div>

  <!-- Thèmes -->
  <section class="max-w-2xl mx-auto px-4 py-10">
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Tous les guides</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      {clusters.map((cluster) => (
        <a
          href={`/${cluster.slug}`}
          class="flex items-center justify-between px-4 py-3 rounded-lg border border-gray-200 hover:border-gray-400 hover:bg-gray-50 transition-colors group text-sm"
        >
          <span class="text-gray-800 font-medium">{cluster.name}</span>
          <span class="text-gray-400 group-hover:text-gray-600">→</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Articles récents -->
  {recent.length > 0 && (
    <section class="max-w-2xl mx-auto px-4 pb-16">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Derniers articles</h2>
      <div class="divide-y divide-gray-100">
        {recent.map((article) => (
          <a
            href={`/${article.id}`}
            class="flex flex-col py-4 hover:bg-gray-50 -mx-4 px-4 rounded-lg transition-colors group"
          >
            <span class="text-xs text-gray-400 mb-1">{article.data.cluster}</span>
            <span class="font-medium text-gray-900 group-hover:text-gray-600 mb-1 leading-snug">
              {article.data.title}
            </span>
            <span class="text-sm text-gray-500">{article.data.description}</span>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>

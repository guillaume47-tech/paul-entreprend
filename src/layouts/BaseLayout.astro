---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = ogImage ?? new URL('/og-default.png', Astro.site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Paul Entreprend" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:site" content="@paulentreprend" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <header class="max-w-2xl mx-auto px-4 py-5 flex items-center justify-between">
      <a href="/" class="font-semibold text-gray-900 hover:text-gray-600 transition-colors">
        Paul Entreprend
      </a>
      <nav class="flex gap-5 text-sm text-gray-500">
        <a href="/micro-entreprise" class="hover:text-gray-900 transition-colors">Micro</a>
        <a href="/sasu" class="hover:text-gray-900 transition-colors">SASU</a>
        <a href="/comparatifs" class="hover:text-gray-900 transition-colors">Comparatifs</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="max-w-2xl mx-auto px-4 py-10 mt-10 border-t border-gray-100">
      <div class="flex flex-col sm:flex-row justify-between gap-3 text-sm text-gray-400">
        <span>© 2026 Paul Entreprend</span>
        <div class="flex gap-4">
          <a href="/mentions-legales" class="hover:text-gray-600 transition-colors">Mentions légales</a>
          <a href="/contact" class="hover:text-gray-600 transition-colors">Contact</a>
        </div>
      </div>
      <p class="mt-3 text-xs text-gray-400">
        Informations à titre indicatif — consultez un professionnel pour votre situation.
      </p>
    </footer>
  </body>
</html>

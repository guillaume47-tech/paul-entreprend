---
import BaseLayout from './BaseLayout.astro';
import '../styles/article.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  cluster: string;
  clusterSlug?: string;
  slug: string;
  schema?: object;
  faq?: { question: string; answer: string }[];
  howToSteps?: { name: string; text: string }[];
}

const { title, description, pubDate, updatedDate, cluster, clusterSlug, slug, schema, faq, howToSteps } = Astro.props;

const canonicalURL = new URL(`/${slug}`, 'https://paul-entreprend.fr').href;
const clusterUrl = `/${clusterSlug ?? cluster.toLowerCase().replace(/ /g, '-')}`;

const dateDisplay = (updatedDate ?? pubDate).toLocaleDateString('fr-FR', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const articleSchema = schema ?? {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${canonicalURL}#article`,
  "headline": title,
  "description": description,
  "url": canonicalURL,
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL },
  "inLanguage": "fr-FR",
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate ?? pubDate).toISOString(),
  "author": {
    "@type": "Person",
    "name": "Paul",
    "url": "https://paul-entreprend.fr/a-propos"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Paul Entreprend",
    "url": "https://paul-entreprend.fr",
    "@id": "https://paul-entreprend.fr/#organization"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://paul-entreprend.fr" },
    { "@type": "ListItem", "position": 2, "name": cluster, "item": `https://paul-entreprend.fr${clusterUrl}` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
  ]
};

const faqSchema = faq?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": { "@type": "Answer", "text": answer }
  }))
} : null;

const howToSchema = howToSteps?.length ? {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": title,
  "step": howToSteps.map(({ name, text }, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": name,
    "text": text
  }))
} : null;
---

<BaseLayout title={`${title} | Paul Entreprend`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}

  <nav class="breadcrumb">
    <a href="/">Accueil</a><span>›</span>
    <a href={clusterUrl}>{cluster}</a><span>›</span>
    {title}
  </nav>

  <article class="paul">
    <slot />
    <p class="disclaimer">Cet article est rédigé à titre informatif et ne constitue pas un conseil juridique. Pour des situations complexes, consulte un avocat ou un expert-comptable.</p>
  </article>
</BaseLayout>

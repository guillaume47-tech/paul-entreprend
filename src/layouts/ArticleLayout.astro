---
import BaseLayout from './BaseLayout.astro';
import '../styles/article.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  cluster: string;
  clusterSlug?: string;
  slug: string;
  schema?: object;
}

const { title, description, pubDate, updatedDate, cluster, clusterSlug, slug, schema } = Astro.props;

const dateDisplay = (updatedDate ?? pubDate).toLocaleDateString('fr-FR', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const schemaJson = schema ?? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate ?? pubDate).toISOString(),
  "author": {
    "@type": "Person",
    "name": "Paul",
    "url": "https://paul-entreprend.fr/a-propos"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Paul Entreprend",
    "url": "https://paul-entreprend.fr"
  }
};
---

<BaseLayout title={`${title} | Paul Entreprend`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />

  <nav class="breadcrumb">
    <a href="/">Accueil</a><span>›</span>
    <a href={`/${clusterSlug ?? cluster.toLowerCase().replace(/ /g, '-')}`}>{cluster}</a><span>›</span>
    {title}
  </nav>

  <article class="paul">
    <slot />
    <p class="disclaimer">Cet article est rédigé à titre informatif et ne constitue pas un conseil juridique. Pour des situations complexes, consulte un avocat ou un expert-comptable.</p>
  </article>
</BaseLayout>
